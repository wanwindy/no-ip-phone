PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=privacy_dialer
DB_USER=app
DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=
REDIS_PASSWORD=

RATE_LIMIT_DRIVER=memory
RATE_LIMIT_ALLOW_FALLBACK=true
RATE_LIMIT_RETRY_COOLDOWN_MS=30000
# Release / pre-prod baseline:
# NODE_ENV=production
# RATE_LIMIT_DRIVER=redis
# RATE_LIMIT_ALLOW_FALLBACK=false
# REDIS_URL=redis://redis:6379
# SMS_PROVIDER=<real-provider>
# noop is local-only. The current build still needs a real SMS provider
# implementation before production / pre-release validation can pass.

JWT_SECRET=replace-me
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_DAYS=30

SMS_PROVIDER=noop
AUTH_FIXED_CODE=123456
# Planned real providers: aliyun / tencent
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
